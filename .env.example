# Copy this file to ".env" in the same folder and fill in your real values.
# Never commit the real ".env" file anywhere public.

# --- Email (Gmail SMTP) ---
# 1. Turn on 2-Step Verification on your Google account:
#    https://myaccount.google.com/security
# 2. Create an "App password": https://myaccount.google.com/apppasswords
#    (choose app "Mail", device "Other" -> name it e.g. "hyrox-watch")
# 3. Paste the 16-character app password below (no spaces).
GMAIL_ADDRESS=ciancagliniantonio@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
# Optional: send to a different address than GMAIL_ADDRESS. Defaults to GMAIL_ADDRESS.
NOTIFY_EMAIL_TO=ciancagliniantonio@gmail.com

# --- SMS (Twilio) ---
# 1. Create a free Twilio account: https://www.twilio.com/try-twilio
# 2. Get a Twilio phone number (trial accounts get one free number).
# 3. Find your Account SID and Auth Token on the Twilio console dashboard.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# Your mobile number to receive the SMS alert, in E.164 format (e.g. +61...).
NOTIFY_SMS_TO=+61XXXXXXXXX
